  "score_definition": {
    "score_name": "Addiction Score",
    "range": [
      0,
      100
    ],
    "components": [
      {
        "feature_key": "daily_hours",
        "frontend_key": "dailyHours",
        "label": "Daily phone usage",
        "weight": 0.18,
        "minimum_code": 1,
        "maximum_code": 4,
        "rationale": "Long daily usage increases compulsive exposure time."
      },
      {
        "feature_key": "checking_frequency",
        "frontend_key": "checkingFrequency",
        "label": "Checking frequency",
        "weight": 0.14,
        "minimum_code": 1,
        "maximum_code": 4,
        "rationale": "Frequent checking is a strong behavioral marker of dependence."
      },
      {
        "feature_key": "before_sleep",
        "frontend_key": "beforeSleep",
        "label": "Before-sleep use",
        "weight": 0.1,
        "minimum_code": 1,
        "maximum_code": 3,
        "rationale": "Night-time use is linked to habit reinforcement and poorer self-control."
      },
      {
        "feature_key": "wake_check",
        "frontend_key": null,
        "label": "Wake-up checking",
        "weight": 0.07,
        "minimum_code": 1,
        "maximum_code": 4,
        "rationale": "Immediate morning checking signals routine-driven dependence."
      },
      {
        "feature_key": "anxious_without_phone",
        "frontend_key": "anxiousWithoutPhone",
        "label": "Anxiety without phone",
        "weight": 0.1,
        "minimum_code": 0,
        "maximum_code": 2,
        "rationale": "Anxiety without the phone reflects emotional attachment to access."
      },
      {
        "feature_key": "study_distraction",
        "frontend_key": "studyDistraction",
        "label": "Study distraction",
        "weight": 0.12,
        "minimum_code": 1,
        "maximum_code": 4,
        "rationale": "Distraction during study indicates direct interference with academic focus."
