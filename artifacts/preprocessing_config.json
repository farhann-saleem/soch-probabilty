        "weight": 0.07,
        "minimum_code": 1,
        "maximum_code": 4,
        "rationale": "Using the phone during class signals poor control in restricted settings."
      },
      {
        "feature_key": "sleep_affected",
        "frontend_key": null,
        "label": "Sleep affected",
        "weight": 0.08,
        "minimum_code": 0,
        "maximum_code": 2,
        "rationale": "Sleep impact is a meaningful downstream consequence of excessive use."
